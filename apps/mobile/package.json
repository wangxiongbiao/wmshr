{
  "name": "@wmshr/mobile",
  "private": true,
  "version": "0.1.5",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "tsc --noEmit",
    "export:web": "expo export -p web --output-dir dist-web",
    "export:web:online": "EXPO_PUBLIC_API_BASE_URL=https://admin.dutylix.com EXPO_PUBLIC_APP_ENV=production expo export -p web --output-dir dist-web",
    "prebuild:ios": "expo prebuild --platform ios",
    "build:android:preview": "npx eas-cli build -p android --profile preview",
    "build:android:preview:online": "npx eas-cli build -p android --profile preview_online",
    "build:android:production": "npx eas-cli build -p android --profile production",
    "build:android:production:online": "npx eas-cli build -p android --profile production_online",
    "submit:android:internal": "npx eas-cli submit -p android --profile internal --latest",
    "submit:android:production": "npx eas-cli submit -p android --profile production --latest",
    "release:android:internal": "npx eas-cli build -p android --profile production --auto-submit-with-profile internal",
    "release:android:production": "npx eas-cli build -p android --profile production_online --auto-submit-with-profile production_online",
    "build:ios:preview": "npx eas-cli build -p ios --profile preview",
    "build:ios:production": "npx eas-cli build -p ios --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@wmshr/i18n": "*",
    "expo": "~54.0.35",
    "expo-asset": "~12.0.13",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-intent-launcher": "~13.0.7",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "i18next": "^26.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "0.21.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  }
}

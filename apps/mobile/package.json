{
  "name": "@wmshr/mobile",
  "private": true,
  "version": "0.1.25",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "tsc --noEmit",
    "export:web": "expo export -p web --output-dir dist-web",
    "export:web:online": "EXPO_PUBLIC_API_BASE_URL=https://admin.dutylix.com EXPO_PUBLIC_APP_ENV=production expo export -p web --output-dir dist-web",
    "prebuild:ios": "expo prebuild --platform ios",
    "build:android:local": "bash ../../scripts/build-mobile-android-local.sh",
    "build:android:production": "npm run build:android:production:local",
    "build:android:production:local": "bash ../../scripts/build-mobile-android-production-local.sh",
    "build:android:production:online:local": "bash ../../scripts/build-mobile-android-production-online-local.sh",
    "build:android:production:bundle:local": "bash ../../scripts/build-mobile-android-production-bundle-local.sh"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-community/datetimepicker": "8.4.4",
    "@wmshr/i18n": "*",
    "expo": "~54.0.35",
    "expo-asset": "~12.0.13",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-intent-launcher": "~13.0.7",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "i18next": "^26.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1314.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "0.21.0",
    "react-native-webview": "^13.16.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  }
}

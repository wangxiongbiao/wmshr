# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
ADMIN_API_BASE_URL="http://127.0.0.1:8788"
VITE_ADMIN_PORTAL_URL="http://localhost:3000"
VITE_ANDROID_DOWNLOAD_URL="https://expo.dev/artifacts/eas/6ZB1qU7jksmLFkVqfAFWzr.apk"

# Public fallback used only when the portal API cannot reach the admin API.
PUBLIC_ANDROID_RELEASE_VERSION="0.1.29"
PUBLIC_ANDROID_RELEASE_CONTENT="例行更新，修复已知问题并优化使用体验"
PUBLIC_ANDROID_RELEASE_URL="https://github.com/wangxiongbiao/wmshr/releases/download/android-0.1.29/wmshr-android-0.1.29.apk"

{
  "name": "wmshr",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:home": "npm --workspace @wmshr/home run dev",
    "dev:admin": "npm --workspace @wmshr/admin run dev",
    "dev:admin:api": "npm --workspace @wmshr/admin run dev:api",
    "dev:mobile": "npm --workspace @wmshr/mobile run start",
    "prepare:desktop:config:local": "cp electron/runtime-config.local.json electron/runtime-config.json",
    "prepare:desktop:config:online": "cp electron/runtime-config.online.json electron/runtime-config.json",
    "export:mobile:web": "npm --workspace @wmshr/mobile run export:web",
    "export:mobile:web:online": "npm --workspace @wmshr/mobile run export:web:online",
    "desktop:dev": "npm run prepare:desktop:config:local && npm run export:mobile:web && electron .",
    "build:desktop:mac": "npm run prepare:desktop:config:local && npm run export:mobile:web && electron-builder --mac",
    "build:desktop:mac:dir": "npm run prepare:desktop:config:local && npm run export:mobile:web && electron-builder --mac dir",
    "build:desktop:mac:online": "npm run prepare:desktop:config:online && npm run export:mobile:web:online && electron-builder --mac --config electron-builder.online.json",
    "build:desktop:mac:online:dir": "npm run prepare:desktop:config:online && npm run export:mobile:web:online && electron-builder --mac dir --config electron-builder.online.json",
    "build:admin": "npm --workspace @wmshr/admin run build",
    "build:home": "npm --workspace @wmshr/home run build",
    "mobile:update-android-release": "node scripts/update-mobile-android-release.mjs",
    "mobile:build:android:production": "npm --workspace @wmshr/mobile run build:android:production",
    "mobile:build:android:production:local": "npm --workspace @wmshr/mobile run build:android:production:local",
    "mobile:build:android:production:online:local": "npm --workspace @wmshr/mobile run build:android:production:online:local",
    "mobile:build:android:production:bundle:local": "npm --workspace @wmshr/mobile run build:android:production:bundle:local",
    "mobile:build:android:production:online": "npm --workspace @wmshr/mobile run build:android:production:online",
    "mobile:release:android": "bash scripts/release-mobile-android.sh",
    "mobile:setup:google-play-key": "bash scripts/setup-google-play-service-account.sh",
    "mobile:release:android:play": "bash scripts/release-mobile-android-play.sh",
    "mobile:adb:wifi": "bash scripts/adb-connect-wifi.sh",
    "mobile:install:android:debug": "bash scripts/adb-install-mobile-debug.sh",
    "mobile:install:android:release": "bash scripts/adb-install-mobile-release.sh",
    "mobile:launch:android": "bash scripts/adb-launch-mobile-app.sh",
    "mobile:log:android": "bash scripts/adb-log-mobile-app.sh",
    "lint": "npm run lint --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "check:i18n": "node scripts/check-i18n-hardcoded.mjs",
    "restart:dev": "bash scripts/restart-dev-services.sh",
    "deploy:prod": "bash scripts/deploy-production.sh"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.wmshr.desktop",
    "productName": "WMSHR App",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release/mac"
    },
    "files": [
      "electron/**/*",
      "apps/mobile/dist-web/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.business",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "overrides": {
    "expo-font": "~14.0.12",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "expo-font": "~14.0.12"
  }
}
